DATABASE_URL=postgresql://vgp:vgp_dev_password@127.0.0.1:5432/vgp
VGP_PORT=8000
VGP_PIPELINE_POLL_SECONDS=0.5
VGP_MAX_PIPELINE_BACKLOG=1000
VGP_MAX_BATCH_INGEST_ITEMS=100
VGP_EVIDENCE_DIR=data/evidence
VGP_MEDIA_DIR=data/media_assets
VGP_MAX_MEDIA_BYTES=524288000
VGP_COPY_LOCAL_MEDIA=true
VGP_ENABLE_REMOTE_DOWNLOAD=false
VGP_REMOTE_DOWNLOAD_TIMEOUT_SECONDS=30
VGP_FFMPEG_PATH=
VGP_FFPROBE_PATH=
VGP_ASR_MODEL_URL=
VGP_OCR_MODEL_URL=
VGP_VISION_MODEL_URL=
VGP_MODEL_API_KEY=
VGP_MODEL_TIMEOUT_SECONDS=30

# Optional model gateway. Start with:
#   python -m backend.model_gateway
# Then point all three modality URLs to this single gateway.
MODEL_GATEWAY_HOST=127.0.0.1
MODEL_GATEWAY_PORT=9001
MODEL_GATEWAY_API_KEY=
MODEL_GATEWAY_TIMEOUT_SECONDS=30
MODEL_GATEWAY_ASR_PROVIDER=local
MODEL_GATEWAY_OCR_PROVIDER=local
MODEL_GATEWAY_VISION_PROVIDER=local
MODEL_GATEWAY_ASR_UPSTREAM_URL=
MODEL_GATEWAY_OCR_UPSTREAM_URL=
MODEL_GATEWAY_VISION_UPSTREAM_URL=
MODEL_GATEWAY_UPSTREAM_API_KEY=

# Optional Azure AI Vision adapter for OCR/vision.
# Set MODEL_GATEWAY_OCR_PROVIDER=azure_vision and/or
# MODEL_GATEWAY_VISION_PROVIDER=azure_vision to enable.
AZURE_VISION_ENDPOINT=
AZURE_VISION_KEY=
AZURE_VISION_API_VERSION=2024-02-01

# Optional OpenAI-compatible LLM review. Leave blank to use local rules only.
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=https://api.openai.com/v1
